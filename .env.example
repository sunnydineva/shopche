# Environment Variables Configuration
# Copy this file to .env and update with your actual values
# DO NOT commit the .env file to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MySQL Root Password
MYSQL_ROOT_PASSWORD=your-secure-root-password

# Main Database Configuration
MYSQL_DATABASE=online_shop
MYSQL_USER=shop_user
MYSQL_PASSWORD=your-secure-shop-password

# Category Service Database Configuration
CATEGORY_MYSQL_DATABASE=category_service
CATEGORY_MYSQL_USER=shop_user
CATEGORY_MYSQL_PASSWORD=your-secure-category-password

# Spring Datasource Configuration
SPRING_DATASOURCE_USERNAME=shop_user
SPRING_DATASOURCE_PASSWORD=your-secure-shop-password

# Category Service Datasource Configuration
CATEGORY_SPRING_DATASOURCE_USERNAME=shop_user
CATEGORY_SPRING_DATASOURCE_PASSWORD=your-secure-category-password

# =============================================================================
# AI SERVICE CONFIGURATION
# =============================================================================

# OpenAI API Key for AI service
OPENAI_API_KEY=your-openai-api-key-here

# =============================================================================
# EMAIL SERVICE CONFIGURATION (Optional)
# =============================================================================

# Email service configuration
SPRING_MAIL_HOST=mailhog
SPRING_MAIL_PORT=1025
# Email service credentials (leave empty for MailHog development setup)
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# =============================================================================
# MESSAGING CONFIGURATION
# =============================================================================

# Kafka bootstrap servers for event-driven communication
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# =============================================================================
# SECURITY CONFIGURATION (Optional - for production)
# =============================================================================

# JWT Secret Key (generate a secure random string for production)
JWT_SECRET=your-jwt-secret-key-make-it-long-and-secure-for-production

# =============================================================================
# EXAMPLE VALUES FOR QUICK SETUP
# =============================================================================
# For development, you can use these example values:
# MYSQL_ROOT_PASSWORD=devpassword123
# MYSQL_PASSWORD=devshop123
# CATEGORY_MYSQL_PASSWORD=devcat123
# SPRING_DATASOURCE_PASSWORD=devshop123
# CATEGORY_SPRING_DATASOURCE_PASSWORD=devcat123
# OPENAI_API_KEY=sk-your-actual-openai-key-here
